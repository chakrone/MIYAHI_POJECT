# ============================================================
# MIYAHI IoT Water Monitoring Platform — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- PostgreSQL (Relational Data) ---
PG_HOST=postgres
PG_PORT=5432
PG_DB=miyahi
PG_USER=miyahi
PG_PASSWORD=change_me

# --- TimescaleDB (Time-Series Data) ---
TS_HOST=timescaledb
TS_PORT=5432
TS_DB=miyahi_ts
TS_USER=miyahi
TS_PASSWORD=change_me

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- MQTT Broker ---
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=miyahi_backend
MQTT_PASSWORD=change_me

# --- Eureka Service Discovery ---
EUREKA_HOST=eureka-server
EUREKA_PORT=8761

# --- Config Server ---
CONFIG_HOST=config-server
CONFIG_PORT=8888

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me

# --- JWT Secret (API Gateway) ---
JWT_SECRET=change_me_must_be_at_least_32_bytes_long

# --- OpenWeatherMap ---
OWM_API_KEY=your_api_key_here
OWM_CITY=Casablanca
OWM_COUNTRY=MA

# --- Twilio (SMS Alerts) ---
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_FROM_NUMBER=+1234567890

# --- SendGrid (Email Alerts) ---
SENDGRID_API_KEY=your_key_here
SENDGRID_FROM_EMAIL=alerts@miyahi.ma
